  @@index([configId])
}

model WhatsAppAutomation {
  id                    Int                     @id @default(autoincrement())
  sessionId             Int
  organizationId        Int
  companyId             Int
  templateId            Int?
  name                  String
  description           String?
  triggerEvent          String
  triggerFilters        Json?
  recipients            String[]
  delayMinutes          Int                     @default(0)
  isActive              Boolean                 @default(true)
  lastTriggered         DateTime?
  triggerCount          Int                     @default(0)
  createdAt             DateTime                @default(now())
  updatedAt             DateTime @updatedAt
  company               Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  organization          Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  session               WhatsAppSession         @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  template              WhatsAppTemplate?       @relation(fields: [templateId], references: [id])
  logs                  WhatsAppAutomationLog[]

  @@index([isActive])
  @@index([organizationId, companyId])
  @@index([sessionId])
  @@index([triggerEvent])
}

model WhatsAppAutomationLog {
  id                 Int                @id @default(autoincrement())
  automationId       Int
  triggeredBy        String
  payload            Json
  recipient          String
  messageSent        Boolean            @default(false)
  errorMessage       String?
  executedAt         DateTime           @default(now())
  automation         WhatsAppAutomation @relation(fields: [automationId], references: [id], onDelete: Cascade)

  @@index([automationId])
  @@index([executedAt])
}

model WhatsAppMessage {
  id                    Int                   @id @default(autoincrement())
  sessionId             Int
  organizationId        Int
  companyId             Int
  remoteJid             String
  messageType           WhatsAppMessageType   @default(TEXT)
  content               String
  mediaUrl              String?
  isFromMe              Boolean               @default(true)
  status                WhatsAppMessageStatus @default(PENDING)
  errorMessage          String?
  quotedMessageId       Int?
  clientId              Int?
  salesId               Int?
  invoiceId             Int?
  sentAt                DateTime?
  deliveredAt           DateTime?
  readAt                DateTime?
  createdAt             DateTime              @default(now())
  client                Client?               @relation(fields: [clientId], references: [id])
  company               Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoiceSales          InvoiceSales?         @relation(fields: [invoiceId], references: [id])
  organization          Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parentMessage         WhatsAppMessage?      @relation("WhatsAppMessageToWhatsAppMessage", fields: [quotedMessageId], references: [id])
  replies               WhatsAppMessage[]     @relation("WhatsAppMessageToWhatsAppMessage")
  sale                  Sales?                @relation(fields: [salesId], references: [id])
  session               WhatsAppSession       @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([createdAt])
  @@index([organizationId, companyId])
  @@index([remoteJid])
  @@index([salesId])
  @@index([sessionId])
}

model WhatsAppSession {
  id                 Int                   @id @default(autoincrement())
  organizationId     Int
  companyId          Int
