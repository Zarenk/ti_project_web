// ── Payment Orchestration ──────────────────────────────────
// New module: does NOT modify any existing table.
// orderId/salesId are informational references (no FK) to avoid
// touching Orders or Sales models.

model PaymentOrder {
  id                 Int       @id @default(autoincrement())
  code               String    @unique

  // Informational references — NO FK to avoid coupling
  orderId            Int?
  salesId            Int?

  // Amount
  amount             Decimal   @db.Decimal(12, 2)
  currency           String    @default("PEN")

  // Provider chosen by orchestrator
  provider           String    // culqi | mercadopago | cobrana | manual
  providerPaymentId  String?

  // State machine: PENDING → PROCESSING → SETTLING → COMPLETED / FAILED / EXPIRED / REFUNDED
  status             String    @default("PENDING")

  // Client info
  clientName         String?
  clientEmail        String?
  clientPhone        String?

  // Payment link
  paymentUrl         String?
  expiresAt          DateTime?

  // Provider response
  providerResponse   Json?
  completedAt        DateTime?
  failedAt           DateTime?
  failureReason      String?

  // Monetary (immutable after COMPLETED)
  grossAmount        Decimal?  @db.Decimal(12, 2)
  netAmount          Decimal?  @db.Decimal(12, 2)
  commissionAmount   Decimal?  @db.Decimal(12, 2)
  commissionRate     Decimal?  @db.Decimal(5, 4)

  // Operational
  idempotencyKey     String?   @unique
  lastWebhookAt      DateTime?
  webhookAttempts    Int       @default(0)

  // Multi-tenant
  organizationId     Int
  companyId          Int?
  createdBy          Int?

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  events             PaymentOrderEvent[]

  @@unique([provider, providerPaymentId])
  @@index([organizationId, status])
  @@index([organizationId, createdAt])
  @@index([status, lastWebhookAt])
  @@index([code])
}

model PaymentOrderEvent {
  id              Int      @id @default(autoincrement())
  paymentOrderId  Int
  fromStatus      String
  toStatus        String
  reason          String?
  metadata        Json?
  createdAt       DateTime @default(now())

  paymentOrder    PaymentOrder @relation(fields: [paymentOrderId], references: [id], onDelete: Cascade)

  @@index([paymentOrderId, createdAt])
}

// ── Libro de Reclamaciones (DS 101-2022-PCM, Ley 29571) ─────────────────────

model complaint_book {
  id                  Int       @id @default(autoincrement())
  organizationId      Int
  companyId           Int
  correlativeNumber   String    // "000000001-2026"
  year                Int
  trackingCode        String    @unique // "LR-A1B2C3D4"
  status              String    @default("PENDING") // PENDING | RESPONDED | OVERDUE

  // Sección 1: Identificación del consumidor reclamante
  consumerName        String
  consumerDocType     String    // DNI, CE
  consumerDocNumber   String
  consumerAddress     String?
  consumerPhone       String?
  consumerEmail       String
  isMinor             Boolean   @default(false)
  parentName          String?
  parentDocType       String?
  parentDocNumber     String?

  // Sección 2: Identificación del bien contratado
  goodType            String    // PRODUCTO, SERVICIO
  claimedAmount       Float?
  amountCurrency      String    @default("PEN")
  goodDescription     String

  // Sección 3: Detalle de la reclamación y pedido del consumidor
  complaintType       String    // RECLAMO, QUEJA
  detail              String
  consumerRequest     String
  reclassified        Boolean   @default(false)
  reclassifiedAt      DateTime?
  reclassifiedBy      Int?

  // Firma virtual (equivalente digital)
  signatureConfirmed  Boolean   @default(true)
  signatureTimestamp  DateTime  @default(now())

  // Sección 4: Observaciones y acciones adoptadas por el proveedor
  responseText        String?
  responseDate        DateTime?
  respondedByUserId   Int?

  // Plazos (15 días hábiles improrrogables)
  deadlineDate        DateTime
  businessDaysUsed    Int?

  // Auditoría de emails enviados
  emailSentToConsumer Boolean   @default(false)
  emailSentAt         DateTime?
  responseEmailSentAt DateTime?

  // Snapshot datos del proveedor (congelados al momento de creación)
  providerLegalName   String
  providerRuc         String
  providerAddress     String

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Relations
  organization        Organization @relation(fields: [organizationId], references: [id])
  company             Company      @relation(fields: [companyId], references: [id])
  respondedBy         User?        @relation("complaintResponder", fields: [respondedByUserId], references: [id])

  @@unique([companyId, correlativeNumber, year])
  @@index([organizationId, companyId])
  @@index([trackingCode])
  @@index([status])
  @@index([deadlineDate])
  @@index([companyId, year])
}
