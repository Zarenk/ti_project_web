# ===================================
# JURISPRUDENCE SYSTEM - ENV VARS
# ===================================
# Copiar estas variables a tu archivo .env principal

# OpenAI API Key (REQUERIDO para embeddings y RAG)
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Embedding Configuration
JURISPRUDENCE_EMBEDDING_MODEL=text-embedding-3-small
JURISPRUDENCE_CHUNK_SIZE=1000
JURISPRUDENCE_CHUNK_OVERLAP=200

# RAG Configuration
JURISPRUDENCE_CHAT_MODEL=gpt-4o-mini
JURISPRUDENCE_TOP_K=5
JURISPRUDENCE_MIN_SIMILARITY=0.7

# Scraping Configuration
JURISPRUDENCE_SCRAPING_ENABLED=true
JURISPRUDENCE_SCRAPING_DELAY=2000

# Storage Configuration
JURISPRUDENCE_STORAGE_PATH=./uploads/jurisprudence
JURISPRUDENCE_MAX_FILE_SIZE=52428800

# ===================================
# NOTAS:
# ===================================
# - OPENAI_API_KEY: Obtener de https://platform.openai.com/api-keys
# - EMBEDDING_MODEL: text-embedding-3-small (1536 dims) - NO cambiar sin migración de BD
# - CHUNK_SIZE: Tamaño en caracteres de cada chunk (1000 es óptimo para legal)
# - CHUNK_OVERLAP: Overlap entre chunks para mantener contexto
# - CHAT_MODEL: gpt-4o-mini es el más económico con buena calidad
# - TOP_K: Número de chunks a recuperar en búsqueda vectorial
# - MIN_SIMILARITY: Umbral de similitud coseno (0.7 es conservador)
# - SCRAPING_DELAY: Delay en ms entre requests (2000 = 2s, obligatorio por ética)
# - STORAGE_PATH: Ruta donde se guardan los PDFs
# - MAX_FILE_SIZE: Tamaño máximo de PDF en bytes (50MB = 52428800)
