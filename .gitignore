# Database backups (may contain sensitive data)
*.sql
!backend/prisma/migrations/**/*.sql

# Env files
.env
.env.*
!.env.example
!.env.*.example

# Logs
*.log
backend/backend-logs.txt

# OS
.DS_Store
Thumbs.db

# IDE tool configs (large skill directories)
.agents/
.claude/
.windsurf/

# Uploaded files
backend/uploads/

# Docs that are local-only
CHECKLIST_PRE_DEPLOY.md

# Playwright CLI captures
.playwright-cli/

# Cypress screenshots (generated on test runs)
fronted/cypress/screenshots/

# Database backup dumps
backups/
*.dump

# OCR traineddata (large binary)
backend/spa.traineddata
*.traineddata

# Temporary test scripts
backend/test-jurisprudence*.sh

# Cypress credentials (NEVER commit)
fronted/cypress.env.json

# Auto-backups (may contain org data)
backend/storage/auto-backups/

# Local packages and build artifacts
.localpkgs/
artifacts/
